# Frontend-safe public config only. Never put OPENAI_API_KEY here.
# Create this as a Google OAuth Web Client ID and add http://localhost:5173 as an authorized JavaScript origin.
VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE_URL=http://localhost:8787
VITE_DEMO_USER_ID=demo

# Backend-only config. Never expose OPENAI_API_KEY with a VITE_ prefix.
API_PORT=8787
CLIENT_ORIGIN=http://127.0.0.1:5173
DATABASE_PATH=server/data/dashboard.sqlite
GOOGLE_CLIENT_ID=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Production storage for Vercel. Keep the service role key backend-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
